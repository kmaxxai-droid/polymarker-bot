# Telegram
TELEGRAM_BOT_TOKEN=123456789:telegram_token
TELEGRAM_CHAT_ID=123456789

# Polygon RPC and wallet (MetaMask account private key)
POLYGON_RPC_URL=https://polygon-rpc.com
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
CHAIN_ID=137

# Polymarket / market discovery
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
MAX_CANDIDATES=30
MAX_LIQUIDITY_USD=1000
MIN_EDGE=0.03
MAX_EVENT_HORIZON_DAYS=14

# Trade risk controls
BET_MIN_USD=5
BET_MAX_USD=10
MAX_SLIPPAGE_BPS=150
AUTO_MODE=false

# Optional executor smart contract (if you route orders via your own contract)
BET_EXECUTOR_CONTRACT=0x0000000000000000000000000000000000000000
BET_EXECUTOR_ABI_PATH=abi/bet_executor.json

# Storage
SQLITE_PATH=data/polymarket_bot.db
